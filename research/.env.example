# Anthropic
ANTHROPIC_API_KEY=your_api_key_here

# Notion
# 1. https://www.notion.so/my-integrations 에서 Integration 생성
# 2. 분석 결과를 저장할 Notion 페이지를 Integration에 공유
# 3. 페이지 URL의 마지막 32자리가 PAGE_ID (하이픈 없이)
NOTION_TOKEN=secret_...
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack (둘 중 하나만 설정해도 됨)
# Webhook 방식: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Bot Token 방식: https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL=#kdt-competitor-analysis
